{
  "name": "@horogen/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "lint": "eslint .",
    "typecheck": "pnpm run generate && tsc --noEmit",
    "test": "pnpm run generate && vitest run",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "pnpm run generate && tsx --env-file-if-exists=.env src/seed.ts"
  },
  "prisma": {
    "seed": "tsx --env-file-if-exists=.env src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "@horogen/config": "workspace:*",
    "@types/node": "^22",
    "eslint": "^9.17.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
