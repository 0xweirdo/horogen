# ────────────────────────────────────────────────────────────
# Local dev — ค่าด้านล่างตรงกับ docker-compose.yml (ไม่ใช่ secret จริง)
# Secret จริงทุกตัวอยู่ใน Doppler (project: heygen-th, configs: dev/staging/prod)
# ห้าม commit .env — .gitignore บล็อกไว้แล้ว
# ────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://heygen:heygen@localhost:5433/heygen_dev
REDIS_URL=redis://localhost:6379

# MinIO (แทน Cloudflare R2 บน local)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=heygen-dev
S3_REGION=auto

# ───── ใช้จริงใน phase ถัดไป — ใส่ค่าผ่าน Doppler เท่านั้น ─────
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=southeastasia
RESEND_API_KEY=
SENTRY_DSN=
